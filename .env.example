# NEXUS Environment Configuration Template

# Core AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEFAULT_MODEL=minimax/minimax-m2.5
# Tiered Model Stack (OpenRouter Slugs)
PRIMARY_BRAIN_MODEL=minimax/minimax-m2.5      # Best tool calling + agentic loops
BROWSER_RESEARCH_MODEL=z-ai/glm-5             # #1 BrowseComp, best web reasoning
FAST_LOOPS_MODEL=google/gemini-2.0-flash     # Cheapest fast model
FALLBACK_PRECISION_MODEL=anthropic/claude-3-5-sonnet # Best self-correction, reliability

# Routing logic:
# Incoming task
#       ↓
# Is it browser/research heavy?
#   YES → GLM-5
#   NO  ↓
# Is it simple/fast (search, format, classify)?
#   YES → Gemini 2.0 Flash
#   NO  ↓
# Is it complex multi-step tool calling?
#   YES → MiniMax M2.5 (default)
#       ↓
# Did it fail or need precision?
#   YES → Claude 3.5 Sonnet (fallback)

# System Configuration
DEBUG=True
LOG_LEVEL=INFO
APP_SECRET_KEY=generate_a_random_hex_string_here

# Channel Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Tool Specific Keys
SERPAPI_API_KEY=your_serpapi_key_here
BROWSERLESS_API_KEY=your_browserless_api_key_here
VERCEL_TOKEN=your_vercel_token_here
GITHUB_TOKEN=your_github_token_here
N8N_API_KEY=your_n8n_api_key_here

# Database / Memory
DATABASE_URL=sqlite:///./nexus.db
REDIS_URL=redis://localhost:6379/0

# Social / Media
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
